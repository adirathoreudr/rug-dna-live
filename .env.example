# GoldRush / Covalent API Key
# Get yours at: https://goldrush.dev
GOLDRUSH_API_KEY=cqt_your_key_here

# Postgres (Neon) — required in production; without it the app
# falls back to a per-process in-memory store (local dev only)
DATABASE_URL=postgres://user:password@host/dbname

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Anthropic for AI narratives
ANTHROPIC_API_KEY=sk-ant-your_key_here
